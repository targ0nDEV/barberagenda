# O MVP atual usa dados mockados/localStorage e sobe na Vercel sem banco.
# Quando conectar banco real, configure uma DATABASE_URL PostgreSQL.
DATABASE_URL="file:./dev.db"

# Reservado para quando NextAuth/Clerk for ativado em producao.
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="troque-por-uma-chave-forte"

# Envio real de e-mail de confirmacao via Resend.
# Crie uma chave em https://resend.com e configure estes valores na Vercel.
RESEND_API_KEY="re_xxxxxxxxx"
EMAIL_FROM="Agende sua consulta <noreply@seudominio.com>"
